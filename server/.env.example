# Domain for HTTPS (Caddy auto-provisions Let's Encrypt certificates)
# Set to your actual domain in production, e.g.: analytics.myapp.com
BANANA_DOMAIN=localhost

# CORS origins (comma-separated). Restrict in production!
# e.g.: https://myapp.com,https://staging.myapp.com
BANANA_CORS_ORIGINS=*

# MaxMind license key for GeoIP downloads (optional but recommended).
# Without this, the geo dashboard + 3D globe will be empty.
# Sign up free: https://www.maxmind.com/en/geolite2/signup
# Then run: ./scripts/download-geoip.sh
MAXMIND_LICENSE_KEY=
