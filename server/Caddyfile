# Production: $BANANA_DOMAIN is set in your .env (e.g. analytics.example.com)
# Caddy automatically provisions Let's Encrypt TLS certificates.
#
# Routing:
#   /v1/*, /health    → Go backend (bananalytics:8080)
#   everything else   → Next.js dashboard (dashboard:3000)
#                       includes /api/* — these are Next.js API routes that
#                       internally proxy to the Go backend at /v1/*
{$BANANA_DOMAIN:localhost} {
	# Backend ingest + query + health
	@backend path /v1/* /health
	reverse_proxy @backend bananalytics:8080

	# Everything else (dashboard pages + Next.js /api/* proxy routes)
	reverse_proxy dashboard:3000

	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	# Request size limit (matches Go server's 5MB limit on ingest)
	request_body {
		max_size 5MB
	}

	# Access log
	log {
		output stdout
		format json
	}
}
